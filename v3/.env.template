# v3 environment configuration
# Copy to .env and fill in real values.  (.env is gitignored at repo root)

# ---- Azure OpenAI (required, used only for reasoning/routing — NOT data) ----
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ---- MCP servers ----
# All data access happens through MCP servers you configure in config/mcp_servers.json.
# Point this at a different file if you like:
# MCP_CONFIG_PATH=config/mcp_servers.json

# Any ${VAR} placeholders inside mcp_servers.json are expanded from this .env,
# so you can keep secrets/URLs here, e.g.:
# ICM_MCP_URL=http://localhost:8080/mcp
# KUSTO_MCP_TOKEN=...
