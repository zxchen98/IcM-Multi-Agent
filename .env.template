# IcM Multi-Agent System Environment Configuration Template
# =======================================================
# Copy this file to .env and fill in your actual values
# Make sure .env is added to .gitignore to keep credentials secure

# Azure OpenAI Configuration (Required)
# =====================================
# Get these values from your Azure OpenAI resource in Azure Portal
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# How to get these values:
# 1. Go to Azure Portal → Your OpenAI Resource
# 2. Navigate to "Keys and Endpoint" section
# 3. Copy the endpoint URL and one of the API keys
# 4. Go to "Model deployments" to find your deployment name

# Optional: Kusto Configuration
# =============================
# The system uses DefaultAzureCredential for authentication
# Uncomment and customize these if you need to override defaults
# KUSTO_CLUSTER_URL=https://icmcluster.kusto.windows.net
# KUSTO_DATABASE=IcMDataWarehouse

# Optional: Debug and Development Settings
# =======================================
# Uncomment these for development/debugging
# DEBUG_MODE=true
# VERBOSE_LOGGING=true

# Instructions:
# =============
# 1. Copy this file: cp .env.template .env (or copy .env.template .env on Windows)
# 2. Replace all placeholder values with your actual Azure OpenAI credentials
# 3. Ensure .env is in your .gitignore file to prevent committing secrets
# 4. Run 'az login' for Azure authentication before starting the system
# 5. Connect to VPN if accessing corporate Kusto clusters
